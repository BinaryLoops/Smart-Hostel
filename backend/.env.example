## Smart Hostel API (backend)
## Copy to `.env` and fill values.

# Server
PORT=4000
# CORS_ORIGIN=http://localhost:5173

# Firebase Admin (required for Firestore persistence + verified auth)
# Option A (recommended locally): use a service account JSON via env var
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option B: use Application Default Credentials (ADC)
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\serviceAccount.json

